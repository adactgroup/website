<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns="http://www.adac.com.au" targetNamespace="http://www.adac.com.au" elementFormDefault="qualified" attributeFormDefault="unqualified" version="5.0.1">
	<!-- INCLUDES -->
	<!-- Enumerated Types -->
	<xs:include schemaLocation="./ADACEnumeratedTypes.xsd">
		<xs:annotation>
			<xs:documentation>Uses ADAC enumerated SimpleType definitions</xs:documentation>
		</xs:annotation>
	</xs:include>
	<!-- Global Types -->
	<xs:include schemaLocation="./ADACGlobalTypes.xsd">
		<xs:annotation>
			<xs:documentation>Contains ADAC globally referenced type definitions</xs:documentation>
		</xs:annotation>
	</xs:include>
	<!-- Geometry -->
	<xs:include schemaLocation="./ADACGeometry.xsd">
		<xs:annotation>
			<xs:documentation>Contains ADAC geometry definitions</xs:documentation>
		</xs:annotation>
	</xs:include>
	<!-- **************************************************************************************** -->
	<!-- OpenSpace - Contains the specification for all OpenSpace information                     -->
	<!-- **************************************************************************************** -->
	<xs:complexType name="objectModelOpenSpace">
		<xs:annotation>
			<xs:documentation>Data structure constraining information relating to public open space features.</xs:documentation>
		</xs:annotation>
		<xs:sequence minOccurs="1" maxOccurs="1">
			<xs:element name="OpenSpaceAreas" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of open space areas</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="OpenSpaceArea" type="Feature_OpenSpace_OpenSpaceArea" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents an open space area feature</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="ActivityAreas" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of activity areas</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="ActivityArea" type="Feature_OpenSpace_ActivityArea" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents an activity area feature</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
      <xs:element name="ActivityLandscapeEdging" nillable="false" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Represents the Edging of an Activity Area or Landscaped Area</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence minOccurs="1" maxOccurs="1">
            <xs:element name="Edging" type="Feature_OpenSpace_Edging" nillable="false" minOccurs="0" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents the Edging of an Activity Area or Landscaped Area</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
			<xs:element name="ActivityPoints" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of activity points</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="ActivityPoint" type="Feature_OpenSpace_ActivityPoint" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents an activity point feature.  E.g: Animal, Fitness, Play or Sports activity item.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Barbeques" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of barbeques</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="Barbeque" type="Feature_OpenSpace_Barbeque" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a barbeque feature</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Tables" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of Tables</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="Table" type="Feature_OpenSpace_Table" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a table feature.  May include fixed seating.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Seats" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of seats.  Does not include seating that is part of a table feature.</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="Seat" type="Feature_OpenSpace_Seat" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a seat feature.  Includes freestanding seats and border seating mounted in garden walls.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="WasteCollectionPoints" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of waste collection points</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="WasteCollectionPoint" type="Feature_OpenSpace_WasteCollectionPoint" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a waste collection point feature</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="BicycleFittings" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of bicycle fittings</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="BicycleFitting" type="Feature_OpenSpace_BicycleFitting" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a bicycle fitting feature</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="GeneralFixtures" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of general fixtures.</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="Fixture" type="Feature_OpenSpace_Fixture" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a general fixture feature.  This is a class of minor point based fixtures not complex enough for a specific feature class.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="BarriersContinuous" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of continuous linear barriers.</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="BarrierContinuous" type="Feature_OpenSpace_BarrierContinuous" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a continuous linear barrier feature, such as fencing, walls, handrail or bollard run.</xs:documentation>
								<xs:documentation>Do not use for retaining walls.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="BarriersPoint" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of point barriers.</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="BarrierPoint" type="Feature_OpenSpace_BarrierPoint" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a barrier feature that controls access at a single point, such as a locking post or single bollard.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="RetainingWalls" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of retaining walls.</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="RetainingWall" type="Feature_OpenSpace_RetainingWall" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a continuous retaining wall feature.  Includes terrestrial, freshwater and marine revetment walls.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Shelters" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of shelters</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:choice minOccurs="0" maxOccurs="unbounded">
						<xs:element name="Shelter" type="Feature_OpenSpace_Shelter" nillable="false" minOccurs="1" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a shelter feature as a Point object</xs:documentation>
							</xs:annotation>
						</xs:element>
            <xs:element name="ShelterPolygon" type="Feature_OpenSpace_Shelter_Polygon" nillable="false" minOccurs="1" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents a shelter feature as a Polygon object</xs:documentation>
              </xs:annotation>
            </xs:element>
					</xs:choice>
				</xs:complexType>
			</xs:element>
			<xs:element name="Artworks" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of open space artworks</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="Artwork" type="Feature_OpenSpace_Artwork" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents an open space artwork feature</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Buildings" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of open space buildings</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="Building" type="Feature_OpenSpace_Building" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents an open space building feature, such as a toilet block, bandstand.</xs:documentation>
								<xs:documentation>Not to be used for shelters.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="BoatingFacilities" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of boating facilities</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="BoatingFacility" type="Feature_OpenSpace_BoatingFacility" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a boating facility feature, such as a pontoon, ramp or jetty.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="ElectricalFittings" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of electrical fittings</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="ElectricalFitting" type="Feature_OpenSpace_ElectricalFitting" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents an electrical fitting point feature, including lighting, whether freestanding or fixed to an existing structure.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="ElectricalConduits" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of electrical conduits</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="ElectricalConduit" type="Feature_OpenSpace_ElectricalConduit" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a continuous linear course of electrical conduit.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="LandscapeAreas" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of landscape areas</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="LandscapeArea" type="Feature_OpenSpace_LandscapeArea" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a landscape area feature, such as a garden, shaped lawn, or landscape feature area.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Trees" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of trees</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="Tree" type="Feature_OpenSpace_Tree" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a tree feature.  Trees may qualify as assets when planted as street trees, or when significant specimens are retained or planted as part of an open space development.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Signs" nillable="false" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Represents the feature class of signs</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence minOccurs="1" maxOccurs="1">
						<xs:element name="Sign" type="Feature_OpenSpace_Sign" nillable="false" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Represents a sign feature</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<!-- **************************************************************************************** -->
	<!-- Features - Contains the specification for all OpenSpace Features                         -->
	<!-- **************************************************************************************** -->
	<!-- Feature OpenSpace OpenSpace Area -->
	<xs:complexType name="Feature_OpenSpace_OpenSpaceArea">
		<xs:annotation>
			<xs:documentation>Represents a top-level area of open space regarded as a single functional area, such as a park or recreation area.  May be, but not necessarily, coincident with cadastral boundary.</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="asset_abstract">
				<xs:sequence minOccurs="1" maxOccurs="1">
					<xs:element name="Name" type="String_64" nillable="false" minOccurs="1" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>
                The offical  name or description  of the Open Space area  (eg: Smith St Park, Stockland Park Sporting complex)
              </xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="Type" type="openspace_area_type" nillable="false" minOccurs="1" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>
                The type of Open Space area eg: Recreational, Bushland, Sporting Complex
              </xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="Geometry" type="geometry_area_multipatch_complex" nillable="false" minOccurs="1" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>The geometry representing this feature in coordinate space.</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<!-- Feature OpenSpace Activity Area -->
	<xs:complexType name="Feature_OpenSpace_ActivityArea">
		<xs:annotation>
			<xs:documentation>Represents an activity area such as a playground or excercise area</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="asset_abstract">
				<xs:sequence minOccurs="1" maxOccurs="1">
					<xs:element name="Use" type="openspace_activity_area_use" nillable="false" minOccurs="1" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>
                The type of use for the  Activity Site eg: Animal, Fitness, Play, Sport
              </xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="Type" type="String_64" nillable="false" minOccurs="1" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>
                The type of Activity Site. Eg: Sports Field, Cycling Facility
              </xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="Material" type="openspace_activity_area_material" nillable="false" minOccurs="1" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>
                The material type of Undersurfacing eg: Bark, Rubber, Grassed
              </xs:documentation>
						</xs:annotation>
					</xs:element>
          <xs:element name="Thickness_mm" type="Float_Positive_NonZero" nillable="false" minOccurs="1" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>Thickness of the material in millimetres.</xs:documentation>
            </xs:annotation>
          </xs:element>
					<xs:element name="Geometry" type="geometry_area_multipatch_complex" nillable="false" minOccurs="1" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>The geometry representing this feature in coordinate space.</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
  <!-- Feature OpenSpace Activity/Landscaping Edging -->
  <xs:complexType name="Feature_OpenSpace_Edging">
    <xs:annotation>
      <xs:documentation>Represents the Edging of an Activity Area or Landscaped Area</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="asset_abstract">
        <xs:sequence minOccurs="1" maxOccurs="1">
          <xs:element name="Material" type="openspace_edge_material" nillable="false" minOccurs="1" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>The material type of edging</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Length_m" type="Float_Positive_NonZero" nillable="false" minOccurs="1" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>Length of material in metres.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Width_mm" type="xs:positiveInteger" nillable="false" minOccurs="1" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>Width of material in millimetres.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Geometry" type="geometry_linear_singlepath_complex" nillable="false" minOccurs="1" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>The geometry representing this feature in coordinate space.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <!-- Feature OpenSpace Activity Point -->
	<xs:complexType name="Feature_OpenSpace_ActivityPoint">
		<xs:annotation>
			<xs:documentation>Represents an installation of animal, play, fitness or sports equipment</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="asset_abstract">
				<xs:sequence minOccurs="1" maxOccurs="1">
					<xs:element name="Use" type="openspace_activity_item_use" nillable="false" minOccurs="1" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>
                The activity use category
              </xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="Type" type="String_64" nillable="false" minOccurs="1" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>
                The activity item type
              </xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="Material" type="openspace_activity_item_material" nillable="false" minOccurs="1" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>
                The material type of Activity Item eg: Timber, Aluminium
              </xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="Theme" type="String_64" nillable="true" minOccurs="1" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>
                The theme of the Activity item. Eg: Kangaroo, Boat, Fort, Car
              </xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="Units" type="xs:positiveInteger" nillable="true" minOccurs="1" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>
                The number of units present eg: 1, 2, 3
              </xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:group ref="manufacturer_model_details" minOccurs="1" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>Standard element group called in to support manufacturer and model details</xs:documentation>
						</xs:annotation>
					</xs:group>
					<xs:element name="Geometry" type="geometry_point_singlepoint" nillable="false" minOccurs="1" maxOccurs="1">
						<xs:annotation>
