<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns="http://www.adac.com.au" targetNamespace="http://www.adac.com.au" elementFormDefault="qualified" attributeFormDefault="unqualified" version="6.0.0">
  <xs:annotation>
    <xs:documentation>The ADAC Transport Schema constrains the data structure for all transport features within an ADAC Project</xs:documentation>
  </xs:annotation>
  <!-- INCLUDES -->
  <!-- Enumerated Types -->
  <xs:include schemaLocation="./ADACEnumeratedTypes.xsd">
    <xs:annotation>
      <xs:documentation>Uses ADAC enumerated SimpleType definitions</xs:documentation>
    </xs:annotation>
  </xs:include>
  <!-- Global Types -->
  <xs:include schemaLocation="./ADACGlobalTypes.xsd">
    <xs:annotation>
      <xs:documentation>Uses ADAC globally referenced type definitions</xs:documentation>
    </xs:annotation>
  </xs:include>
  <!-- Geometry -->
  <xs:include schemaLocation="./ADACGeometry.xsd">
    <xs:annotation>
      <xs:documentation>Uses ADAC geometry definitions</xs:documentation>
    </xs:annotation>
  </xs:include>
  <!-- **************************************************************************************** -->
  <!-- Transport - contains the specification for all Transport feature classes                 -->
  <!-- **************************************************************************************** -->
  <xs:complexType name="objectModelTransport">
    <xs:annotation>
      <xs:documentation>Data structure constraining information on road related features.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="PavementAreas" minOccurs="1" maxOccurs="1" nillable="false">
        <xs:annotation>
          <xs:documentation>Represents the featureclass of road pavement areas</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence minOccurs="1" maxOccurs="1">
            <xs:element name="Pavement" type="Feature_Transport_Pavement" minOccurs="0" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents an area of road pavement.</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="ParkingAreas" minOccurs="1" maxOccurs="1" nillable="false">
        <xs:annotation>
          <xs:documentation>Represents the featureclass of parking areas</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence minOccurs="1" maxOccurs="1">
            <xs:element name="Parking" type="Feature_Transport_Parking" minOccurs="0" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents an area of parking pavement.</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="RoadEdges" minOccurs="1" maxOccurs="1" nillable="false">
        <xs:annotation>
          <xs:documentation>Represents the featureclass of road edges</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence minOccurs="1" maxOccurs="1">
            <xs:element name="RoadEdge" type="Feature_Transport_RoadEdge" minOccurs="0" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents an edge feature of a pavement area.</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="RoadIslands" minOccurs="1" maxOccurs="1" nillable="false">
        <xs:annotation>
          <xs:documentation>Represents the featureclass of road islands</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence minOccurs="1" maxOccurs="1">
            <xs:element name="RoadIsland" type="Feature_Transport_RoadIsland" minOccurs="0" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents an area of road island , local traffic calming, or median structure.  Where the structure incorporates water sensitive urban design (WSUD) features, those features should be independently captured.</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="Pathways" minOccurs="1" maxOccurs="1" nillable="false">
        <xs:annotation>
          <xs:documentation>Represents the featureclass of pathways.  Subtypes are provided for the correct validation of in-ground paths, on-road cycleways and structures functioning as part of a linear path network.</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:choice minOccurs="0" maxOccurs="unbounded">
            <xs:element name="Pathway" type="Feature_Transport_Pathway" minOccurs="1" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents an on-ground footpath or cycleway feature.  Do not use to describe on-road cycleway.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="RoadPathway" type="Feature_Transport_RoadPathway" minOccurs="1" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents a linear section of on-road cycleway.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="PathStructure" type="Feature_Transport_PathStructure" minOccurs="1" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents a structure functioning as a linear section of footpath or cycleway.  Do not use to describe on-road cycleway.</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:choice>
        </xs:complexType>
      </xs:element>
      <xs:element name="RoadSafetyBarriers" minOccurs="1" maxOccurs="1" nillable="false">
        <xs:annotation>
          <xs:documentation>Represents the featureclass of transport barriers</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence minOccurs="1" maxOccurs="1">
            <xs:element name="RoadSafetyBarrier" type="Feature_Transport_RoadSafetyBarrier" minOccurs="0" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents a barrier dedicated to transport features.</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="PramRamps" minOccurs="1" maxOccurs="1" nillable="false">
        <xs:complexType>
          <xs:choice minOccurs="0" maxOccurs="unbounded">
            <xs:element name="PramRamp" type="Feature_Transport_PramRamp" minOccurs="1" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents a pram ramp or disabled entry-point to a road edge as a Point object</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="PramRampPolygon" type="Feature_Transport_PramRamp_Polygon" minOccurs="1" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents a pram ramp or disabled entry-point to a road edge as a Polygon object</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:choice>
        </xs:complexType>
      </xs:element>
      <xs:element name="SubSoilDrains" minOccurs="1" maxOccurs="1" nillable="false">
        <xs:complexType>
          <xs:sequence minOccurs="1" maxOccurs="1">
            <xs:element name="SubSoilDrain" type="Feature_Transport_SubSoilDrain" minOccurs="0" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents a road sub-soil drain.  Formerly called RoadSubsoilDrain in ADAC Version 3.0.1</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="FlushPoints" minOccurs="1" maxOccurs="1" nillable="false">
        <xs:complexType>
          <xs:sequence minOccurs="1" maxOccurs="1">
            <xs:element name="FlushPoint" type="Feature_Transport_DrainFlushPoint" minOccurs="0" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents a sub-soil drain flush point.</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="Bridges" minOccurs="1" maxOccurs="1" nillable="false">
        <xs:annotation>
          <xs:documentation>Represents the featureclass of bridges.</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:choice minOccurs="0" maxOccurs="unbounded">
            <xs:element name="BridgeExtent" type="Feature_Transport_BridgeExtent" minOccurs="1" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Describes the envelope or footprint for the whole structure and all of its parts. It holds properties that apply at the assembly level.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="BridgeDeck" type="Feature_Transport_BridgeDeck" minOccurs="1" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents a single deck unit between abutments or supports. There may be one or more BridgeDeck objects for any given bridge assembly.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="BridgeSuperstructure" type="Feature_Transport_BridgeSuperstructure" minOccurs="1" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents superstructure of bridge.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="BridgeAbutment" type="Feature_Transport_BridgeAbutment" minOccurs="1" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents the extent of one abutment for a bridge assembly. A BridgeAbutment will be independently described at each end of the structure.</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="BridgePier" type="Feature_Transport_BridgePier" minOccurs="1" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Represents a single supporting structure that supports deck spans between abutments.</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:choice>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
  <!-- **************************************************************************************** -->
  <!-- FEATURES  - Transport                                                                    -->
  <!-- **************************************************************************************** -->
  <!-- FEATURE TRANSPORT PAVEMENT -->
  <xs:complexType name="Feature_Transport_Pavement" abstract="false">
    <xs:annotation>
      <xs:documentation>Represents an area of road pavement.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="asset_abstract">
        <xs:sequence minOccurs="1" maxOccurs="1">
          <xs:element name="Name" type="String_254" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>The gazetted, or proposed, road name.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Surface" type="transport_surface_struct" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Data container for surface characteristics.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PavementStructure" type="transport_pavement_struct" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Data container for pavement structure characteristics.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PavementHierarchy" type="transport_pavement_hierarchy" minOccurs="1" maxOccurs="1" nillable="true">
            <xs:annotation>
              <xs:documentation>Pavement hierarchy</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PavementGeoTextile" type="transport_pavement_geotextile" minOccurs="1" maxOccurs="1" nillable="true">
            <xs:annotation>
              <xs:documentation>Pavement geotextile type.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SubGrade" type="transport_pavement_subgrade_struct" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Data container for subgrade structure characteristics.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Geometry" type="geometry_area_multipatch_complex">
            <xs:annotation>
              <xs:documentation>Polygon geometry delineating the pavement area in coordinate space.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <!-- FEATURE TRANSPORT PARKING -->
  <xs:complexType name="Feature_Transport_Parking" abstract="false">
    <xs:annotation>
      <xs:documentation>Represents an area of parking pavement.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="asset_abstract">
        <xs:sequence minOccurs="1" maxOccurs="1">
          <xs:element name="Name" type="String_254" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Parking area name</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="NoOfCarparks" type="xs:positiveInteger" minOccurs="1" maxOccurs="1" nillable="true">
            <xs:annotation>
              <xs:documentation>Number of individual vehicle spaces.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="OnOffStreet" type="transport_parking_onoff" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Value indicating whether the parking is an uninterupted part of the road pavement, or a seperate area with road access.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Surface" type="parking_surface_struct" minOccurs="1" maxOccurs="1" nillable="true">
            <xs:annotation>
              <xs:documentation>Data container for surface characteristics.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PavementStructure" type="transport_pavement_struct" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Data container for pavement structure characteristics.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PavementGeoTextile" type="transport_pavement_geotextile" minOccurs="1" maxOccurs="1" nillable="true">
            <xs:annotation>
              <xs:documentation>Pavement geotextile type.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SubGrade" type="transport_pavement_subgrade_struct" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Data container for subgrade structure characteristics.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Geometry" type="geometry_area_multipatch_complex">
            <xs:annotation>
              <xs:documentation>Polygon geometry delineating the pavement area in coordinate space.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <!-- FEATURE TRANSPORT ROADEDGE -->
  <xs:complexType name="Feature_Transport_RoadEdge" abstract="false">
    <xs:annotation>
      <xs:documentation>Represents an edge feature of a pavement area.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="asset_abstract">
        <xs:sequence minOccurs="1" maxOccurs="1">
          <xs:element name="Type" type="transport_edge_type" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Road edge configuration.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Material" type="transport_edge_material" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Material of Road edge.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Width_mm" type="xs:positiveInteger" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Width in millimetres of the Edge feature.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Length_m" type="Float_Positive_NonZero" minOccurs="1" maxOccurs="1" nillable="true">
            <xs:annotation>
              <xs:documentation>Length in metres of edge material.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PavementExtension_mm" type="xs:positiveInteger" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>The pavement extension, in millimetres, behind the back of kerb.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Geometry" type="geometry_linear_multipath_complex" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Polyline geometry describing the feature in coordinate space.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <!-- FEATURE TRANSPORT ROADISLAND -->
  <xs:complexType name="Feature_Transport_RoadIsland" abstract="false">
    <xs:complexContent>
      <xs:extension base="asset_abstract">
        <xs:sequence minOccurs="1" maxOccurs="1">
          <xs:element name="Type" type="transport_island_type" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>The type of structure.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Area_m2" type="Float_Positive_NonZero" minOccurs="1" maxOccurs="1" nillable="true">
            <xs:annotation>
              <xs:documentation>The area, in square metres, of the infill.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="InfillType" type="transport_island_infill_type" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>The type of infill.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Geometry" type="geometry_area_multipatch_complex" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Polygon geometry describing the feature in coordinate space.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <!-- FEATURE TRANSPORT PATHWAY-->
  <xs:complexType name="Feature_Transport_Pathway" abstract="false">
    <xs:annotation>
      <xs:documentation>Represents a linear section of on ground footpath or off-road cycleway.  Should not be used to describe on-road cycleway.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="asset_abstract">
        <xs:sequence minOccurs="1" maxOccurs="1">
          <xs:element name="Use" type="transport_pathway_use" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Intended traffic use of the structure.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Structure" type="String_32" fixed="In Ground" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Type of pathway structure.  A fixed value of In Ground is required for this sub type</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SurfaceMaterial" type="transport_pathway_surface_material" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Surface material of the structure.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Width_m" type="Float_Positive_NonZero" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Nominal width of the pathway in metres.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Depth_mm" type="xs:positiveInteger" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>The nominal depth of the pathway material in millimetres.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Geometry" type="geometry_linear_singlepath_complex" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Polyline geometry describing the feature in coordinate space.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <!-- FEATURE TRANSPORT ROADPATHWAY-->
  <xs:complexType name="Feature_Transport_RoadPathway" abstract="false">
    <xs:annotation>
      <xs:documentation>Represents a linear section of on on-road cycleway.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="asset_abstract">
        <xs:sequence minOccurs="1" maxOccurs="1">
          <xs:element name="Use" type="transport_pathway_use" fixed ="CycleWay" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Intended traffic use of the structure.</xs:documentation>
              <xs:documentation>A fixed value of CycleWay is applied to this sub type</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Structure" type="String_32" fixed="On Road" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Type of pathway structure.  A fixed value of On Road is required for this sub type</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SurfaceMaterial" type="String_32" fixed="Road Pavement" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Surface material of the structure.</xs:documentation>
              <xs:documentation>A fixed value of Road Pavement is applied to this sub type</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Width_m" type="Float_Positive_NonZero" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Nominal width of the marked pathway in metres.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Geometry" type="geometry_linear_singlepath_complex" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Polyline geometry describing the feature in coordinate space.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <!-- FEATURE TRANSPORT PATHSTRUCTURE -->
  <xs:complexType name="Feature_Transport_PathStructure" abstract="false">
    <xs:annotation>
      <xs:documentation>Represents a linear section of structure that functions as part of a pathway network</xs:documentation>
      <xs:documentation>Note that this type shares the same elements as Feature_Transport_Pathway</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="asset_abstract">
        <xs:sequence minOccurs="1" maxOccurs="1">
          <xs:element name="Use" type="transport_pathway_use" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Intended traffic use of the structure.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Structure" type="transport_pathway_structure" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Type of pathway structure.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SurfaceMaterial" type="transport_path_struction_surface_material" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Surface material of the structure.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SubStructureMaterial" type="transport_pathway_substructure_material" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Material of the sub structure.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Width_m" type="Float_Positive_NonZero" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Nominal width of the pathway in metres.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Geometry" type="geometry_linear_singlepath_complex" minOccurs="1" maxOccurs="1" nillable="false">
            <xs:annotation>
              <xs:documentation>Polyline geometry describing the feature in coordinate space.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <!-- FEATURE TRANSPORT BARRIER -->
  <xs:complexType name="Feature_Transport_RoadSafetyBarrier" abstract="false">
    <xs:annotation>
      <xs:documentation>Represents a barrier dedicated to transport features.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="asset_abstract">
        <xs:sequence minOccurs="1" maxOccurs="1">
