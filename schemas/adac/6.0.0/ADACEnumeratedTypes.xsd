	<!-- Enumerations - General                                                                   -->
	<!-- **************************************************************************************** -->	
	<xs:simpleType name="submission_status">
		<xs:annotation>
			<xs:documentation>The submission status of this ADAC data set.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="String_32">
			<xs:enumeration value="Preliminary">
				<xs:annotation>
					<xs:documentation>This ADAC data set represents a preliminary or design phase.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="For Approval">
				<xs:annotation>
					<xs:documentation>Data has been submitted for approval.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="As Approved">
				<xs:annotation>
					<xs:documentation>Data has been submitted as a record of what was approved incorporating any requirements given in an approval.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="For Amendment">
				<xs:annotation>
					<xs:documentation>Data has been submitted for approval of variations to the original approval.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="As Amended">
				<xs:annotation>
					<xs:documentation>Data has been submitted as a record of an amended approval incorporating any requirements given in an amended approval</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Archive">
				<xs:annotation>
					<xs:documentation>Recieiving entity internal use - Data has been submitted as an archive or backup.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Transfer">
				<xs:annotation>
					<xs:documentation>Receiving entity internal use - Data transfer between systems or entities</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="As Constructed">
				<xs:annotation>
					<xs:documentation>Data has been submitted to describe the actual finished work.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="asset_status">
		<xs:annotation>
			<xs:documentation>The status of the asset at the time the data was captured.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="String_32">
			<xs:enumeration value="Newly Constructed">
				<xs:annotation>
					<xs:documentation>Newly constructed asset being passed to recieivng entity</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Existing">
				<xs:annotation>
					<xs:documentation>Existing asset described as encountered</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Designed">
				<xs:annotation>
					<xs:documentation>Future asset described as a design</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Planned">
				<xs:annotation>
					<xs:documentation>Future asset prior to detailed design</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Removed">
				<xs:annotation>
					<xs:documentation>Previously existing asset described as it was prior to removal</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Retired">
				<xs:annotation>
					<xs:documentation>Pre-existing asset no longer in use, but left in-situ.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Rehabilitated">
				<xs:annotation>
					<xs:documentation>Existing asset repaired, refitted or refurbished as part of works project.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="construction_method">
		<xs:annotation>
			<xs:documentation>Method of construction</xs:documentation>
		</xs:annotation>
		<xs:restriction base="String_32">
			<xs:enumeration value="Prefabricated">
				<xs:annotation>
					<xs:documentation>Prefabricated</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Insitu">
				<xs:annotation>
					<xs:documentation>Built or poured in-situ</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>
	<!--Ben Pham added: DataQuality for each asset-->
	<xs:simpleType name="data_quality">
		<xs:annotation>
			<xs:documentation>Data quality level for each asset</xs:documentation>
		</xs:annotation>
		<xs:restriction base="String_32">
			<xs:enumeration value="A">
				<xs:annotation>
					<xs:documentation>AS5488 quality level A (XYZ +- 50mm Positive identification of attributes and the absolute location in 3D).</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="B">
				<xs:annotation>
					<xs:documentation>AS5488 quality level B (XY +- 300mm Z +-500 mm must be based on survey).</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="C">
				<xs:annotation>
					<xs:documentation>AS5488 quality level C (XY +- 300mm Z not applicable based on survey of visible assets only).</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="D">
				<xs:annotation>
					<xs:documentation>AS5488 quality level D ( XYX tolerance not applicable, lowest level of data quality).</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="APlus">
				<xs:annotation>
					<xs:documentation>Enhanced A with XY +- 50 mm and Z +- 10mm required by by SEQ Code and others for as-constructed data on gravity sewerage.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Other">
				<xs:annotation>
					<xs:documentation>Some other data quality not conforming with AS5488</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Unknown">
				<xs:annotation>
					<xs:documentation>Data quality unknown at time of submission</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>
	<!-- **************************************************************************************** -->
	<!-- Enumerations  - Sewerage                                                                 -->
	<!-- **************************************************************************************** -->
	<xs:simpleType name="sewer_mh_use">
		<xs:annotation>
			<xs:documentation>Allowed uses for a Maintenance Hole</xs:documentation>
		</xs:annotation>
		<xs:restriction base="String_32">
			<xs:enumeration value="Overflow">
				<xs:annotation>
					<xs:documentation>Maintenance Hole with an overflow to the environment, receiving waters or an emergency storage</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
      <xs:enumeration value="Bifurcation">
        <xs:annotation>
          <xs:documentation>Maintenance Hole with two or more outgoing sewer pipes including: [a]  twin pipes (or multiple augmented  pipes) [b] Major bifurcations that divert flows to separate sub-catchments [c] Minor bifurcation that diverts flow for only short distance downstream before merging into same trunk main [d] emergency storage</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
			<xs:enumeration value="Blank End">
				<xs:annotation>
					<xs:documentation>Maintenance hole with no incoming connection</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Pump Station">
				<xs:annotation>
					<xs:documentation>Pit housing a sewer pump station</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Valve Pit">
				<xs:annotation>
					<xs:documentation>Access Pit for a Sewer Valve</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Grit Collector MH">
				<xs:annotation>
					<xs:documentation>Grit Collector Maintenance Hole</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Outlet">
				<xs:annotation>
					<xs:documentation>Outlet</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Rising Main Discharge MH">
				<xs:annotation>
					<xs:documentation>A sewer MH that is the recieiving MH for a rising main discharge</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Vacuum Sewerage Pump Station">
				<xs:annotation>
					<xs:documentation>A pit housing a Vacuum Sewerage Pump Station</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Vacuum Sewerage MH">
				<xs:annotation>
					<xs:documentation>A Maintenance Hole on a vacuum system with incoming house connections or gravity sewers that may also containing a vacuum valve</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Vacuum Lift">
				<xs:annotation>
					<xs:documentation>A chamber on a vacuum system containing a lift or vacuum valve but no incoming laterals</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Storage Tank">
				<xs:annotation>
					<xs:documentation>An off-stream sewage storage tank for emergency or other use</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Maintenance Hole">
				<xs:annotation>
					<xs:documentation>A standard Sewerage Maintenance Hole also known as a Manhole with one outgoing pipe</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Temporary Works">
				<xs:annotation>
					<xs:documentation>A shaft used during construction that is left in place but does not form part of the final infrastruture</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Screen Chamber">
				<xs:annotation>
					<xs:documentation>Maintenance Hole on overflow pipes with screens</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Unknown">
				<xs:annotation>
					<xs:documentation>Chamber of unknown use at time of data submission</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="Other">
				<xs:annotation>
					<xs:documentation>Type of maintenance structure other than those used as standard in the Schema</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>
