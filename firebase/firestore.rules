rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['projects@adact.com.au'];
    }

    function isShortString(value, maximum) {
      return value is string && value.size() <= maximum;
    }

    function validOptionalCoordinate(data, field, minimum, maximum) {
      return !(field in data) || (
        data[field] is number
        && data[field] >= minimum
        && data[field] <= maximum
      );
    }

    function validProjectUpload() {
      let data = request.resource.data;
      return isSignedIn()
        && data.keys().hasAll([
          'visitor_id',
          'session_id',
          'local_file_id',
          'project_name',
          'surveyor_name',
          'engineer_name',
          'receiver',
          'software_product',
          'schema_version',
          'asset_count',
          'coordinate_system',
          'horizontal_datum',
          'source',
          'page_path',
          'created_at'
        ])
        && data.keys().hasOnly([
          'visitor_id',
          'session_id',
          'local_file_id',
          'project_name',
          'surveyor_name',
          'engineer_name',
          'receiver',
          'software_product',
          'schema_version',
          'asset_count',
          'coordinate_system',
          'horizontal_datum',
          'source',
          'page_path',
          'centre_latitude',
          'centre_longitude',
          'minimum_latitude',
          'maximum_latitude',
          'minimum_longitude',
          'maximum_longitude',
          'created_at'
        ])
        && data.visitor_id == request.auth.uid
        && isShortString(data.session_id, 100)
        && isShortString(data.local_file_id, 80)
        && isShortString(data.project_name, 240)
        && isShortString(data.surveyor_name, 240)
        && isShortString(data.engineer_name, 240)
        && isShortString(data.receiver, 240)
        && isShortString(data.software_product, 240)
        && isShortString(data.schema_version, 24)
        && data.asset_count is int
        && data.asset_count >= 0
        && data.asset_count <= 1000000
        && isShortString(data.coordinate_system, 80)
        && isShortString(data.horizontal_datum, 40)
        && data.source == 'uploaded_xml'
        && data.page_path == '/adac-viewer.html'
        && validOptionalCoordinate(data, 'centre_latitude', -90, 90)
        && validOptionalCoordinate(data, 'centre_longitude', -180, 180)
        && validOptionalCoordinate(data, 'minimum_latitude', -90, 90)
        && validOptionalCoordinate(data, 'maximum_latitude', -90, 90)
        && validOptionalCoordinate(data, 'minimum_longitude', -180, 180)
        && validOptionalCoordinate(data, 'maximum_longitude', -180, 180)
        && data.created_at == request.time;
    }

    function validToolEvent() {
      let data = request.resource.data;
      return isSignedIn()
        && data.keys().hasAll([
          'visitor_id',
          'session_id',
          'project_ids',
          'tool_name',
          'page_path',
          'created_at'
        ])
        && data.keys().hasOnly([
          'visitor_id',
          'session_id',
          'project_ids',
          'tool_name',
          'page_path',
          'created_at'
        ])
        && data.visitor_id == request.auth.uid
        && isShortString(data.session_id, 100)
        && data.project_ids is list
        && data.project_ids.size() <= 20
        && data.tool_name in [
          'fullscreen_workspace',
          'multi_asset_selection',
          'filtered_asset_selection',
          'engineering_recalculation',
          'combined_pdf_report',
          'separate_pdf_reports',
          'xml_merge',
          'merged_xml_download',
          'position_shift',
          'simple_labels',
          'as_constructed_labels',
          'distance_measurement',
          'area_measurement',
          'suggested_repair_preview',
          'selected_repair_preview',
          'repaired_xml_download',
          'xml_editing',
          'attribute_edit',
          'bulk_attribute_edit',
          'geometry_coordinate_edit',
          'edit_undo',
          'edit_redo',
          'bulk_edit_undo',
          'bulk_edit_redo',
          'asset_duplicate',
          'line_split',
          'line_join',
          'asset_delete',
          'edited_xml_download',
          'related_field_recalculation',
          'gravity_direction_flip',
          'geometry_snap',
          'vertex_add',
          'vertex_delete'
        ]
        && data.page_path == '/adac-viewer.html'
        && data.created_at == request.time;
    }

    match /project_uploads/{recordId} {
      allow create: if validProjectUpload();
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    match /tool_events/{recordId} {
      allow create: if validToolEvent();
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
